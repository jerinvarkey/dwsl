{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/og-image.jpg", "dest": "/og-image.jpg" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/apple-touch-icon.png", "dest": "/apple-touch-icon.png" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}